---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Prose from '../../../components/Prose.astro';
import Tag from '../../../components/Tag.astro';
import { render } from 'astro:content';
import { getPosts, postSlug, findPostTranslation, postUrl } from '../../../content/helpers';

export async function getStaticPaths() {
  const entries = await getPosts('pt');
  return entries.map((entry) => ({
    params: { slug: postSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, publishedAt, summary, tags } = entry.data;
const dateStr = publishedAt.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });

const enTranslation = await findPostTranslation(entry, 'en');
const altLangHref = enTranslation ? postUrl(enTranslation, 'en') : '/blog';
---

<BaseLayout title={title} lang="pt" description={summary} altLangHref={altLangHref}>
  <article class="space-y-8">
    <header class="space-y-3">
      <p class="text-sm">
        <a href="/pt/blog" class="text-muted hover:text-accent">← Blog</a>
      </p>
      <h1 class="font-serif text-4xl md:text-5xl">{title}</h1>
      <p class="text-sm text-muted">
        <time datetime={publishedAt.toISOString()}>{dateStr}</time>
      </p>
      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 pt-1">
          {tags.map((t: string) => <li><Tag label={t} /></li>)}
        </ul>
      )}
    </header>
    <Prose>
      <Content />
    </Prose>
  </article>
</BaseLayout>
