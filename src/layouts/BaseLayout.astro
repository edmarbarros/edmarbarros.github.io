---
import '../styles/theme.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getUIStrings, type Locale } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
}

const { title, description, lang = 'en', ogImage } = Astro.props;
const t = getUIStrings(lang);
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteTitle = title === t.siteName ? t.siteName : `${title} — ${t.siteName}`;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
    <meta name="twitter:card" content="summary_large_image" />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
    <link rel="alternate" type="application/rss+xml" title="Edmar Barros — Blog (EN)" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Edmar Barros — Blog (PT)" href="/pt/rss.xml" hreflang="pt" />
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader lang={lang} />
    <main class="flex-1 w-full max-w-content mx-auto px-6 py-12">
      <slot />
    </main>
    <SiteFooter lang={lang} />
  </body>
</html>
