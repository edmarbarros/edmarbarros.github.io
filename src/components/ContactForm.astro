---
import type { Locale } from '../i18n';
import { SITE_CONFIG } from '../config';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const labels = {
  en: {
    name: 'Name',
    email: 'Email',
    message: 'Message',
    submit: 'Send',
    sending: 'Sending…',
    verifying: 'Verifying…',
    successTitle: 'Message sent',
    success: 'Thanks — I\u2019ll reply soon.',
    failed: 'Send failed — email hello@edmarbarros.com directly.',
  },
  pt: {
    name: 'Nome',
    email: 'Email',
    message: 'Mensagem',
    submit: 'Enviar',
    sending: 'Enviando…',
    verifying: 'Verificando…',
    successTitle: 'Mensagem enviada',
    success: 'Obrigado — respondo em breve.',
    failed: 'Falha no envio — escreva para hello@edmarbarros.com.',
  },
}[lang];
---

<form
  id="contact-form"
  class="space-y-4 max-w-prose"
  novalidate
  data-endpoint={SITE_CONFIG.contactEndpoint}
  data-label-sending={labels.sending}
  data-label-verifying={labels.verifying}
  data-label-submit={labels.submit}
  data-label-failed={labels.failed}
>
  <label class="block space-y-1">
    <span class="text-sm text-muted">{labels.name}</span>
    <input
      type="text"
      name="name"
      required
      maxlength="200"
      class="w-full bg-transparent border border-border rounded px-3 py-2 focus:border-accent focus:outline-none"
    />
  </label>

  <label class="block space-y-1">
    <span class="text-sm text-muted">{labels.email}</span>
    <input
      type="email"
      name="email"
      required
      maxlength="254"
      class="w-full bg-transparent border border-border rounded px-3 py-2 focus:border-accent focus:outline-none"
    />
  </label>

  <label class="block space-y-1">
    <span class="text-sm text-muted">{labels.message}</span>
    <textarea
      name="message"
      required
      minlength="10"
      maxlength="5000"
      rows="6"
      class="w-full bg-transparent border border-border rounded px-3 py-2 focus:border-accent focus:outline-none"
    ></textarea>
  </label>

  <!-- Honeypot: hidden, must stay empty -->
  <div aria-hidden="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">
    <label>
      Website
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <div
    class="cf-turnstile"
    data-sitekey={SITE_CONFIG.turnstileSiteKey}
    data-theme="auto"
  ></div>

  <input type="hidden" name="ts" />

  <button
    type="submit"
    class="inline-flex items-center gap-2 border border-border px-4 py-2 hover:border-accent hover:text-accent transition-colors"
  >
    {labels.submit}
  </button>

  <p id="contact-status" class="text-sm min-h-[1.5em]" role="status" aria-live="polite"></p>
</form>

<div
  id="contact-success"
  class="max-w-prose border border-border p-6"
  role="status"
  aria-live="polite"
  hidden
>
  <div class="flex items-start gap-3">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-accent shrink-0 mt-1"
      aria-hidden="true"
    >
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
      <polyline points="22 4 12 14.01 9 11.01"></polyline>
    </svg>
    <div class="space-y-1">
      <h2 class="font-serif text-xl">{labels.successTitle}</h2>
      <p class="text-muted">{labels.success}</p>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
  if (form && status) {
    const tsInput = form.querySelector<HTMLInputElement>('input[name="ts"]');
    if (tsInput) tsInput.value = String(Date.now());

    const endpoint = form.dataset.endpoint!;
    const LSending = form.dataset.labelSending!;
    const LVerifying = form.dataset.labelVerifying!;
    const LSubmit = form.dataset.labelSubmit!;
    const LFailed = form.dataset.labelFailed!;
    const successPanel = document.getElementById('contact-success');

    const TURNSTILE_SRC = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    let turnstileInjected = false;
    function injectTurnstile() {
      if (turnstileInjected) return;
      turnstileInjected = true;
      const s = document.createElement('script');
      s.src = TURNSTILE_SRC;
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }

    // Inject on first textarea blur — widget can render before the user reaches submit.
    const msg = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
    msg?.addEventListener('blur', injectTurnstile, { once: true });

    async function waitForToken(maxMs = 10000): Promise<string> {
      const start = Date.now();
      while (Date.now() - start < maxMs) {
        const el = form!.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
        if (el?.value) return el.value;
        await new Promise((r) => setTimeout(r, 100));
      }
      return '';
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = LSending;
      }
      status.textContent = '';

      // Ensure the challenge is loading. If this is the first click (no blur yet), show verifying.
      const alreadyInjected = turnstileInjected;
      injectTurnstile();
      if (!alreadyInjected) status.textContent = LVerifying;

      const token = await waitForToken();
      status.textContent = '';

      const fd = new FormData(form);
      const payload = {
        name: (fd.get('name') as string) || '',
        email: (fd.get('email') as string) || '',
        message: (fd.get('message') as string) || '',
        website: (fd.get('website') as string) || '',
        ts: Number(fd.get('ts')) || Date.now(),
        turnstileToken: token,
      };

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.status === 204) {
          form.hidden = true;
          if (successPanel) successPanel.hidden = false;
        } else {
          status.textContent = LFailed;
        }
      } catch {
        status.textContent = LFailed;
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = LSubmit;
        }
      }
    });
  }
</script>
