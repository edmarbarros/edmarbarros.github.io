---
import Tag from './Tag.astro';
import type { PostEntry } from '../content/helpers';
import type { Locale } from '../i18n';

interface Props {
  entry: PostEntry;
  href: string;
  lang: Locale;
}

const { entry, href, lang } = Astro.props;
const { title, publishedAt, summary, tags } = entry.data;
const fmtLocale = lang === 'en' ? 'en-US' : 'pt-BR';
const dateStr = publishedAt.toLocaleDateString(fmtLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border-b border-border pb-6 last:border-b-0">
  <header class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 mb-2">
    <h3 class="font-serif text-xl">
      <a href={href} class="no-underline text-text hover:text-accent">{title}</a>
    </h3>
    <time class="text-sm text-muted" datetime={publishedAt.toISOString()}>{dateStr}</time>
  </header>
  <p class="max-w-prose mb-3">{summary}</p>
  {tags.length > 0 && (
    <ul class="flex flex-wrap gap-2">
      {tags.map((t: string) => <li><Tag label={t} /></li>)}
    </ul>
  )}
</article>
